      "seq": 1
    },
    {
      "word": "십년감수",
      "meaning": "A narrow escape",
      "example": "정말 십년감수했네요. (That was really a close call.)",
      "audio": "RR_009_v002.mp3",
      "seq": 2
    },
    {
      "word": "살았다",
      "meaning": "I'm saved. I lived",
      "example": "휴. 이제 살았다. (Phew. now I'm saved.)",
